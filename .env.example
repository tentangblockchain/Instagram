# =============================================
# Telegram Bot Configuration
# =============================================

# Token dari @BotFather (wajib)
BOT_TOKEN=your_telegram_bot_token_here

# Telegram user ID admin, pisahkan koma jika lebih dari satu
# Cara cek ID: https://t.me/userinfobot
ADMIN_IDS=123456789,987654321

# Channel yang wajib diikuti sebelum bisa download
# Format: @channelname (koma untuk beberapa channel)
REQUIRED_CHANNEL=@yourchannel

# =============================================
# Saweria Payment Configuration
# =============================================

# Username Saweria kamu (tanpa @)
SAWERIA_USERNAME=yourusername

# UUID Saweria (buka saweria.co/usernamemu → F12 → Network → cari request 'snap')
SAWERIA_USER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# =============================================
# Download Limits
# =============================================

FREE_DAILY_LIMIT=10
VIP_DAILY_LIMIT=100

# =============================================
# Database & Logging
# =============================================

DATABASE_PATH=database.db
DEBUG=False
LOG_LEVEL=INFO
