modules = ["python-3.11"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"
packages = ["nano"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "telegram-bot"

[[workflows.workflow]]
name = "telegram-bot"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python bot/main.py"

[workflows.workflow.metadata]
outputType = "console"

[deployment]
deploymentTarget = "vm"
run = ["python", "bot/main.py"]
build = ["pip", "install", "-r", "requirements.txt"]

[userenv]

[userenv.shared]
ADMIN_IDS = "6185398749,7027694923"
REQUIRED_CHANNEL = "@silviaroyshita_88"
MAX_DOWNLOADS_PER_DAY = "10"
FREE_DAILY_LIMIT = "10"
VIP_DAILY_LIMIT = "100"
TRAKTEER_USERNAME = "yovica"
DATABASE_PATH = "database.db"
DEBUG = "False"
LOG_LEVEL = "INFO"
