modules = ["python-3.11"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"
packages = ["nano"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "telegram-bot"

[[workflows.workflow]]
name = "telegram-bot"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python bot/main.py"

[workflows.workflow.metadata]
outputType = "console"

[deployment]
deploymentTarget = "vm"
run = ["python", "python bot/main.py"]
build = ["pip", "install", "-r", "requirements.txt"]
